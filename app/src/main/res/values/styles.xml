<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.CloudStream" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowBackground">@color/primaryBlackBackground</item>
        <item name="android:statusBarColor">@color/primaryBlackBackground</item>
        <item name="android:navigationBarColor">@color/primaryBlackBackground</item>
    </style>

    <style name="Theme.CloudStream.NoActionBar" parent="Theme.CloudStream">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.CloudStream.Transparent" parent="Theme.CloudStream">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
    </style>

    <style name="AppTheme" parent="Theme.CloudStream"/>
    <style name="AppTheme.NoActionBar" parent="Theme.CloudStream.NoActionBar"/>

    <style name="BlackButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primaryBlackBackground</item>
        <item name="android:textColor">@color/textColor</item>
    </style>

    <style name="WhiteButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primaryWhite</item>
        <item name="android:textColor">@color/primaryBlackBackground</item>
    </style>

    <style name="SettingsItem" parent="Widget.MaterialComponents.TextView">
        <item name="android:textColor">@color/textColor</item>
        <item name="android:background">@color/primaryGrayBackground</item>
        <item name="android:padding">8dp</item>
    </style>

    <style name="CustomIndicator">
        <item name="android:background">@color/colorPrimary</item>
    </style>

    <style name="RoundedImageView">
        <item name="android:background">@color/primaryGrayBackground</item>
    </style>
</resources>
