<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.CloudStream" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowBackground">@color/primaryBlackBackground</item>
        <item name="android:statusBarColor">@color/primaryBlackBackground</item>
        <item name="android:navigationBarColor">@color/primaryBlackBackground</item>
    </style>

    <style name="Theme.CloudStream.NoActionBar" parent="Theme.CloudStream">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.CloudStream.Transparent" parent="Theme.CloudStream">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
    </style>

    <style name="AppTheme" parent="Theme.CloudStream"/>
    <style name="AppTheme.NoActionBar" parent="Theme.CloudStream.NoActionBar"/>

    <style name="BlackButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primaryBlackBackground</item>
        <item name="android:textColor">@color/textColor</item>
    </style>

    <style name="WhiteButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primaryWhite</item>
        <item name="android:textColor">@color/primaryBlackBackground</item>
    </style>

    <style name="SettingsItem" parent="Widget.MaterialComponents.TextView">
        <item name="android:textColor">@color/textColor</item>
        <item name="android:background">@color/primaryGrayBackground</item>
        <item name="android:padding">8dp</item>
    </style>

    <style name="CustomIndicator">
        <item name="android:background">@color/colorPrimary</item>
    </style>

    <style name="RoundedImageView">
        <item name="android:background">@color/primaryGrayBackground</item>
    </style>
    <style name="ResultInfoText">
        <item name="android:layout_gravity">center_vertical</item>
        <item name="textColor">?attr/white</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minHeight">24dp</item>
        <item name="android:minWidth">0dp</item>
    </style>

    <style name="ContinueWatchingPlayUnderlayProgress">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">4dp</item>
        <item name="android:layout_gravity">bottom</item>
        <item name="trackColor">@color/transparent</item>
        <item name="indicatorColor">?attr/colorPrimary</item>
    </style>

    <style name="ContinueWatchingCircularProgress">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_gravity">center</item>
        <item name="trackColor">@color/transparent</item>
        <item name="indicatorColor">?attr/colorPrimary</item>
    </style>

    <style name="DownloadHeaderPlayUnderlayProgress">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">4dp</item>
        <item name="android:layout_gravity">bottom</item>
        <item name="trackColor">@color/transparent</item>
        <item name="indicatorColor">?attr/colorPrimary</item>
    </style>

    <style name="DownloadHeaderCircularProgress">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_gravity">center</item>
        <item name="trackColor">@color/transparent</item>
        <item name="indicatorColor">?attr/colorPrimary</item>
    </style>
</resources>
